# 复制为 .env.production 后按需填写（不要提交含密钥的 .env 到 Git）
# 站点对外域名（Skill 页文档链接等）
# NEXT_PUBLIC_SITE_ORIGIN=https://10unews.com

# ========== 爬虫上游（三选一策略）==========
# 主爬虫，默认 3001；回退时始终用它
UPSTREAM_TRENDING_3001=http://127.0.0.1:3001

# 新爬法基址，例如第二进程 :3002（不填则没有「双上游」）
# UPSTREAM_TRENDING_ALT=http://127.0.0.1:3002

# legacy = 只用主站（最安全，与改之前一致）
# alt = 只用 UPSTREAM_TRENDING_ALT（必须已配置 ALT）
# alt_fallback = 先请求 ALT，失败或非 2xx 再用主站
TRENDING_SOURCE=legacy

# ========== 深度合并（可选）==========
# 1 或 true 时，榜单拉取后再请求 GET /api/enrich/{weibo|douyin|gzh}
# TRENDING_ENRICH=0

# 深度接口单独基址（不填则与上面「当前生效的榜单上游」一致）
# UPSTREAM_ENRICH_BASE=http://127.0.0.1:3003
